{
  "name": "@whyyo/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "tsx dist/src/server.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:e2e-live": "vitest run test/live-backend-e2e.test.ts --passWithNoTests",
    "format": "prettier --check 'src/**/*.ts'",
    "migrate": "tsx src/db/migrate.ts",
    "risk:import": "tsx ../../infrastructure/scripts/import-risk-dataset.ts",
    "risk:verify": "tsx ../../infrastructure/scripts/verify-risk-dataset.ts",
    "seed:aliases": "tsx ../../infrastructure/scripts/seed-dev-aliases.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.0.0",
    "@fastify/rate-limit": "^10.1.0",
    "@fastify/swagger": "^9.4.0",
    "@fastify/swagger-ui": "^5.2.1",
    "@whyyo/domain": "workspace:*",
    "@whyyo/integrations": "workspace:*",
    "@whyyo/shared": "workspace:*",
    "@yo-protocol/core": "*",
    "bullmq": "^5.34.0",
    "fastify": "^5.2.1",
    "ioredis": "^5.4.2",
    "openai": "^4.76.0",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.11",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
