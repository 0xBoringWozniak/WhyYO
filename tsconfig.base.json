{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": false,
    "baseUrl": ".",
    "paths": {
      "@whyyo/shared": ["packages/shared/src"],
      "@whyyo/domain": ["packages/domain/src"],
      "@whyyo/integrations": ["packages/integrations/src"],
      "@whyyo/ui": ["packages/ui/src"]
    }
  }
}
