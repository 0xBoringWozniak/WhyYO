NODE_ENV=development

# Web
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_DEFAULT_CHAIN=base

# API
API_PORT=8080
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info
ENABLE_SWAGGER=true
ENABLE_DEBUG_ENDPOINTS=true
API_RATE_LIMIT_MAX=60
API_RATE_LIMIT_WINDOW_MS=60000

# Postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=whyyo
POSTGRES_USER=whyyo
POSTGRES_PASSWORD=whyyo
DATABASE_URL=postgresql://whyyo:whyyo@postgres:5432/whyyo

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# Debank
DEBANK_ACCESS_KEY=
DEBANK_BASE_URL=https://pro-openapi.debank.com
DEBANK_CACHE_TTL_SEC=90
DEBANK_TIMEOUT_MS=8000
INTEGRATION_TEST_WALLET_ADDRESS=

# Risk dataset bootstrap / storage
RISK_DATASET_SOURCE=file
RISK_DATASET_FILE=/app/data/risk/risk-dataset.json
RISK_DATASET_AUTO_MIGRATE=true
RISK_DATASET_IMPORT_ON_BOOT=true
RISK_DATASET_VERSION=local-dev
RISK_DATASET_REFRESH_CRON=
RISK_DATASET_CACHE_TTL_SEC=1800

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4
OPENAI_EXPLANATION_TEMPERATURE=0.2
ENABLE_EXPLANATION_CACHE=true
ENABLE_ASYNC_EXPLANATIONS=true

# YO
YO_PARTNER_ID=
YO_DEFAULT_SLIPPAGE_BPS=50
YO_API_TIMEOUT_MS=8000

# RPCs
BASE_RPC_URL=
ETHEREUM_RPC_URL=
ARBITRUM_RPC_URL=
OPTIMISM_RPC_URL=
POLYGON_RPC_URL=

# Queue / worker
QUEUE_PREFIX=whyyo

# Optional
SENTRY_DSN=
